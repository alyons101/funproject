# ── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://zbojyyhaqaqlftyizuli.supabase.co

# Use the Anon / Publishable key (safe for client-side code)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_RLUhrV2NFcDMLaskBvISgQ_4EdVY2HZ

# Use the Service Role (secret) key for server-side admin operations.
# If you only have the anon key, use it here too and run the full migration
# (supabase/migrations/001_initial.sql) which adds RLS policies for anon writes.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ── MetalpriceAPI ─────────────────────────────────────────────────────────────
# Sign up at https://metalpriceapi.com (free tier: 100 requests/month)
METAL_PRICE_API_KEY=YOUR_METALPRICE_API_KEY

# ── Resend (email alerts) ─────────────────────────────────────────────────────
# Sign up at https://resend.com and create an API key
RESEND_API_KEY=YOUR_RESEND_API_KEY
# Must match a verified domain in your Resend account
RESEND_FROM_EMAIL=alerts@yourdomain.com

# ── Vercel Cron security ──────────────────────────────────────────────────────
# A random secret shared between Vercel and this app.
# Generate with: openssl rand -hex 32
CRON_SECRET=YOUR_RANDOM_SECRET
