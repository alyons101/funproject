# ── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ── MetalpriceAPI ─────────────────────────────────────────────────────────────
# Sign up at https://metalpriceapi.com (free tier: 100 requests/month)
METAL_PRICE_API_KEY=YOUR_METALPRICE_API_KEY

# ── Resend (email alerts) ─────────────────────────────────────────────────────
# Sign up at https://resend.com and create an API key
RESEND_API_KEY=YOUR_RESEND_API_KEY
# Must match a verified domain in your Resend account
RESEND_FROM_EMAIL=alerts@yourdomain.com

# ── Vercel Cron security ──────────────────────────────────────────────────────
# A random secret shared between Vercel and this app.
# Generate with: openssl rand -hex 32
CRON_SECRET=YOUR_RANDOM_SECRET
